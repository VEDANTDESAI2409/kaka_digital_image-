generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum Role {
  ADMIN
  PHOTOGRAPHER
  EDITOR
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum BookingStatus {
  INQUIRY
  QUOTATION_SENT
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum EventStatus {
  UPCOMING
  SHOOTING
  EDITING
  REVIEW
  DELIVERED
  ARCHIVED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  REFUNDED
}

enum PaymentMethod {
  CASH
  UPI
  BANK_TRANSFER
  CARD
  CHEQUE
}

enum EventType {
  WEDDING
  HALDI
  MEHENDI
  RECEPTION
  ENGAGEMENT
  PRE_WEDDING
  BIRTHDAY
  MATERNITY
  BABY_SHOWER
  CORPORATE
  OTHER
}

enum MediaType {
  PHOTO
  VIDEO
  HIGHLIGHT_FILM
  FULL_MOVIE
  ALBUM_PDF
  PRINT_FILE
  RAW_PHOTO
  RAW_VIDEO
}

enum MediaStatus {
  UPLOADED
  PROCESSING
  EDITING
  REVIEW
  APPROVED
  DELIVERED
  ARCHIVED
}

enum SectionType {
  MANUAL
  AI_GENERATED
  CLIENT_FAVORITES
  HIDDEN
}

enum QRCodeType {
  GALLERY
  GUEST_UPLOAD
}

enum AssignmentRole {
  LEAD_PHOTOGRAPHER
  PHOTOGRAPHER
  CINEMATOGRAPHER
  DRONE_OPERATOR
  EDITOR
  ASSISTANT
}

enum AssignmentStatus {
  ASSIGNED
  ACCEPTED
  IN_PROGRESS
  COMPLETED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  CANCELLED
}

enum GuestSubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

enum SettingType {
  STRING
  NUMBER
  BOOLEAN
  JSON
}

//////////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////////

model User {
  id String @id @default(cuid())

  fullName String
  email    String  @unique
  phone    String? @unique

  passwordHash String

  role   Role
  status UserStatus @default(ACTIVE)

  profileImage String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  assignments              EventAssignment[]
  uploadedMedia            Media[]           @relation("UploadedMedia")
  notifications            Notification[]
  activityLogs             ActivityLog[]
  approvedGuestSubmissions GuestSubmission[]
  updatedSettings          Setting[]

  @@index([email])
  @@index([role])
  @@index([status])
}

//////////////////////////////////////////////////////
// CLIENT
//////////////////////////////////////////////////////

model Client {
  id String @id @default(cuid())

  primaryContactName String

  primaryPhone    String  @unique
  primaryWhatsApp String?
  primaryEmail    String?

  partnerName     String?
  partnerPhone    String?
  partnerWhatsApp String?
  partnerEmail    String?

  address String?
  city    String?
  state   String?
  pincode String?

  notes String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  bookings Booking[]

  @@index([primaryContactName])
  @@index([primaryPhone])
}

//////////////////////////////////////////////////////
// BOOKING
//////////////////////////////////////////////////////

model Booking {
  id String @id @default(cuid())

  bookingNumber String @unique

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Restrict)

  title       String
  description String?

  services Json?

  quotationAmount Decimal @db.Decimal(12, 2)
  advanceAmount   Decimal @default(0) @db.Decimal(12, 2)
  remainingAmount Decimal @db.Decimal(12, 2)

  status BookingStatus @default(INQUIRY)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  events   Event[]
  invoices Invoice[]
  payments Payment[]

  @@index([clientId])
  @@index([status])
  @@index([bookingNumber])
}

//////////////////////////////////////////////////////
// EVENT
//////////////////////////////////////////////////////

model Event {
  id String @id @default(cuid())

  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  title     String
  eventType EventType

  startDate DateTime
  endDate   DateTime?

  venue String?
  city  String?
  state String?

  coverMediaId String?

  coverMedia Media? @relation("EventCover", fields: [coverMediaId], references: [id], onDelete: SetNull)

  status EventStatus @default(UPCOMING)

  galleryToken String? @unique

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  albums           Album[]
  media            Media[]
  guestSubmissions GuestSubmission[]
  qrCodes          QRCode[]
  assignments      EventAssignment[]

  @@index([bookingId])
  @@index([eventType])
  @@index([status])
  @@index([startDate])
}

model Album {
  id String @id @default(cuid())

  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  title       String
  description String?

  coverMediaId String?

  coverMedia Media? @relation("AlbumCover", fields: [coverMediaId], references: [id], onDelete: SetNull)

  sortOrder Int @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  sections Section[]
  media    Media[]

  @@index([eventId])
}

model Section {
  id String @id @default(cuid())

  albumId String
  album   Album  @relation(fields: [albumId], references: [id], onDelete: Cascade)

  title String

  type SectionType @default(MANUAL)

  description String?

  coverImage String?

  sortOrder Int @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  media Media[]

  @@index([albumId])
}

model Media {
  id String @id @default(cuid())

  filename     String
  originalName String
  mimeType     String
  path         String
  size         Int

  type   MediaType
  status MediaStatus @default(UPLOADED)

  uploadedById String
  uploadedBy   User   @relation("UploadedMedia", fields: [uploadedById], references: [id])

  eventId String
  event   Event  @relation(fields: [eventId], references: [id])

  albumId String
  album   Album  @relation(fields: [albumId], references: [id])

  sectionId String?
  section   Section? @relation(fields: [sectionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  eventCover Event[] @relation("EventCover")
  albumCover Album[] @relation("AlbumCover")

  faces Face[]

  @@index([uploadedById])
  @@index([eventId])
  @@index([albumId])
  @@index([sectionId])
  @@index([status])
  @@index([type])
}

model EventAssignment {
  id String @id @default(cuid())

  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  role AssignmentRole

  status AssignmentStatus @default(ASSIGNED)

  assignedAt DateTime @default(now())

  acceptedAt DateTime?

  completedAt DateTime?

  notes String?

  @@index([eventId])
  @@index([userId])
}

model Face {
  id String @id @default(cuid())

  mediaId String
  media   Media  @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  personName String?

  embedding Json?

  confidence Float?

  x Float?
  y Float?

  width  Float?
  height Float?

  createdAt DateTime @default(now())

  @@index([mediaId])
}

model Invoice {
  id String @id @default(cuid())

  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  invoiceNumber String @unique

  totalAmount Decimal @db.Decimal(12, 2)

  taxAmount Decimal @default(0) @db.Decimal(12, 2)

  discountAmount Decimal @default(0) @db.Decimal(12, 2)

  finalAmount Decimal @db.Decimal(12, 2)

  status InvoiceStatus @default(DRAFT)

  issuedAt DateTime?

  dueDate DateTime?

  createdAt DateTime @default(now())

  payments Payment[]

  @@index([bookingId])
}

model Payment {
  id String @id @default(cuid())

  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  amount Decimal @db.Decimal(12, 2)

  status PaymentStatus

  paymentMethod PaymentMethod

  transactionId String?

  paidAt DateTime?

  notes String?

  createdAt DateTime @default(now())

  @@index([bookingId])
  @@index([invoiceId])
}

model GuestSubmission {
  id String @id @default(cuid())

  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  guestName String?

  phone String?

  mediaType MediaType

  storageKey String

  previewKey String?

  status GuestSubmissionStatus @default(PENDING)

  uploadedAt DateTime @default(now())

  approvedById String?

  approvedBy User? @relation(fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([eventId])
}

//////////////////////////////////////////////////////
// QR CODE
//////////////////////////////////////////////////////

model QRCode {
  id String @id @default(cuid())

  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  type QRCodeType

  token String @unique

  maxDownloads Int?

  downloadCount Int @default(0)

  expiresAt DateTime?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  @@index([eventId])
  @@index([token])
}

//////////////////////////////////////////////////////
// NOTIFICATION
//////////////////////////////////////////////////////

model Notification {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title String

  message String

  type NotificationType @default(INFO)

  isRead Boolean   @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
}

//////////////////////////////////////////////////////
// ACTIVITY LOG
//////////////////////////////////////////////////////

model ActivityLog {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  action String

  entity String?

  entityId String?

  metadata Json?

  ipAddress String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
}

//////////////////////////////////////////////////////
// SETTINGS
//////////////////////////////////////////////////////

model Setting {
  id String @id @default(cuid())

  key String @unique

  value String

  type SettingType @default(STRING)

  description String?

  updatedById String?

  updatedBy User? @relation(fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}
